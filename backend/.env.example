# =====================================================================
#  DATABASE
# =====================================================================
DATABASE_URL=postgresql://USER:PASSWORD@host.neon.tech/dbname?sslmode=require

# =====================================================================
#  SERVER
# =====================================================================
PORT=4000
APP_URL=http://localhost:5173
# Extra allowed CORS origins (comma-separated), beyond APP_URL. Optional.
CORS_ORIGINS=

# =====================================================================
#  AUTH / SECURITY
#  JWT_SECRET: openssl rand -base64 48   (or: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
#  CREDENTIAL_ENC_KEY: must be 32 bytes, base64 — node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =====================================================================
JWT_SECRET=
JWT_EXPIRES=7d
CREDENTIAL_ENC_KEY=

# =====================================================================
#  GOOGLE OAUTH — client (candidate) sign-in (server-side code exchange)
# =====================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# =====================================================================
#  GMAIL — sending emails to clients
#  (OAuth tokens for atsapplyexperts@gmail.com)
# =====================================================================
GMAIL_SENDER=atsapplyexperts@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=

# =====================================================================
#  OPENROUTER — all AI features (chat + embeddings)
#  One key covers both. Get key at: https://openrouter.ai/keys
# =====================================================================
OPENROUTER_API_KEY=
# Chat model: resume analysis, job simplification, batch suggestions
OPENROUTER_CHAT_MODEL=google/gemini-2.0-flash-exp:free
# Embed model: resume ↔ job description cosine similarity matching
OPENROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# =====================================================================
#  GOOGLE SHEETS — job batch spreadsheets
#  Paste the full service account JSON as a single line
# =====================================================================
GOOGLE_SERVICE_ACCOUNT={}

# =====================================================================
#  FILE UPLOADS
# =====================================================================
UPLOAD_DIR=./uploads

# =====================================================================
#  ADMIN SEED — run once: node src/jobs/seed-admin.js
# =====================================================================
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# =====================================================================
#  JOBSPY — Python microservice for Indeed, LinkedIn, etc.
# =====================================================================
JOBSPY_ENABLED=false
JOBSPY_URL=http://127.0.0.1:8000
JOBSPY_SITES=indeed,linkedin
JOBSPY_RESULTS=50
JOBSPY_HOURS=72
JOBSPY_COUNTRY=USA
JOBSPY_PROXIES=
